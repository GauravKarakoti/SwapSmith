#!/bin/bash
# Pre-commit hook to detect and prevent secret leakage
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

# Color output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo -e "${YELLOW}[Pre-commit] Checking for secret patterns...${NC}"

# Patterns that indicate secrets
SECRET_PATTERNS=(
    # Private keys (Ethereum and Bitcoin style)
    "^.*=.*0x[a-f0-9]\{64\}"
    "^.*=.*sk_[a-zA-Z0-9]\{20,\}"
    "^.*=.*pk_[a-zA-Z0-9]\{20,\}"
    # API keys
    "api[_-]?key.*[:=]['\"]?[a-zA-Z0-9]\{20,\}"
    # Database URLs with credentials
    "postgresql://.*:.*@"
    "mongodb://.*:.*@"
    # AWS keys
    "AKIA[0-9A-Z]\{16\}"
    # Common secret keywords with values
    "password.*[:=]['\"]?[^'\"]['\"]?"
    "secret.*[:=]['\"][^\"]*['\"]"
)

# Check staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}[Pre-commit] No files to check.${NC}"
    exit 0
fi

FOUND_SECRETS=0

for FILE in $STAGED_FILES; do
    # Skip certain file types
    case "$FILE" in
        *.lock | *.yarn | node_modules/* | .next/* | dist/* | build/* | coverage/* )
            continue
            ;;
    esac

    # Get the staged content
    CONTENT=$(git show ":$FILE" 2>/dev/null || true)
    
    if [ -z "$CONTENT" ]; then
        continue
    fi

    # Check against .env patterns in non-.env files
    if [[ "$FILE" != ".env"* ]]; then
        # Look for suspicious patterns
        if echo "$CONTENT" | grep -iE "NEXT_PUBLIC.*API_KEY\s*=\s*[^=\s]" >/dev/null 2>&1; then
            if ! [[ "$CONTENT" =~ "your_|YOUR_|placeholder|PLACEHOLDER|<|>" ]]; then
                echo -e "${RED}[Pre-commit] POSSIBLE SECRET DETECTED in $FILE: Public API key with actual value${NC}"
                FOUND_SECRETS=1
            fi
        fi
        
        # Check for private key patterns
        if echo "$CONTENT" | grep -iE "PRIVATE_KEY\s*=\s*0x[a-f0-9]{64}" >/dev/null 2>&1; then
            echo -e "${RED}[Pre-commit] CRITICAL: Private key found in $FILE${NC}"
            FOUND_SECRETS=1
        fi
    fi
    
    # Check that .env files are in .gitignore
    if [[ "$FILE" == ".env" ]]; then
        if ! grep -q "^\\.env$" .gitignore 2>/dev/null; then
            echo -e "${RED}[Pre-commit] ERROR: .env file is being committed but not in .gitignore${NC}"
            FOUND_SECRETS=1
        fi
    fi
done

# Check if any .env files are being added
if echo "$STAGED_FILES" | grep -E "\.env(?!\.example)" >/dev/null 2>&1; then
    echo -e "${RED}[Pre-commit] ERROR: Attempting to commit .env file!${NC}"
    echo -e "${YELLOW}[Pre-commit] Use .env.example instead and add .env to .gitignore${NC}"
    FOUND_SECRETS=1
fi

if [ $FOUND_SECRETS -eq 1 ]; then
    echo -e "${RED}[Pre-commit] Secret check FAILED${NC}"
    echo -e "${YELLOW}[Pre-commit] Tips:${NC}"
    echo "  1. Review the files mentioned above"
    echo "  2. Remove any real secrets or API keys"
    echo "  3. Use empty string values in .env.example files"
    echo "  4. Ensure .env and .env.local are in .gitignore"
    echo "  5. Use 'git diff --cached' to review staged changes"
    exit 1
fi

echo -e "${GREEN}[Pre-commit] Secret check PASSED ✓${NC}"
exit 0
