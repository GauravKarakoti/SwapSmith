{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": false,
    "useDefineForClassFields": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "downlevelIteration": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["jest"],
    "paths": {
      "@/*": [
        "./*"
      ],
      "dotenv": [
        "./node_modules/dotenv"
      ],
      "drizzle-kit": [
        "./node_modules/drizzle-kit"
      ],
      "drizzle-orm": [
        "./node_modules/drizzle-orm"
      ],
      "drizzle-orm/*": [
        "./node_modules/drizzle-orm/*"
      ],
      "winston": [
        "./node_modules/winston"
      ],
      "axios": [
        "./node_modules/axios"
      ],
      "@neondatabase/serverless": [
        "./node_modules/@neondatabase/serverless"
      ],
      "zod": [
        "./node_modules/zod"
      ],
      "viem": [
        "./node_modules/viem"
      ],
      "vitest": [
        "./node_modules/vitest"
      ]
    }
  },
  "include": [
    "src/**/*",
    "../shared/**/*"
  ],
  "exclude": [
    "drizzle.config.ts",
    "src/workers/limitOrderWorker.ts",
    "src/workers/price-alerts.ts",
    "../shared/node_modules"
  ]
}
