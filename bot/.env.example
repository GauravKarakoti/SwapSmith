# Telegram Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=

# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=

# Sideshift Integration (optional)
NEXT_PUBLIC_SIDESHIFT_API_KEY=
NEXT_PUBLIC_AFFILIATE_ID=

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
WALLETCONNECT_PROJECT_ID=

# Bot Configuration
PORT=3000
MINI_APP_URL=http://localhost:3001
ADMIN_CHAT_ID=

# Database URL (PostgreSQL)
# Format: postgresql://user:password@hostname:port/database?sslmode=require
DATABASE_URL=

# Sideshift Configuration
SIDESHIFT_CLIENT_IP=127.0.0.1

# Sentry Error Tracking (optional)
SENTRY_DSN=