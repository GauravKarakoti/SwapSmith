{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@shared/*": ["../shared/*"],
      "shared/*": ["../shared/*"],
      "dotenv": ["./node_modules/dotenv"],
      "drizzle-kit": ["./node_modules/drizzle-kit"],
      "drizzle-orm": ["./node_modules/drizzle-orm"],
      "drizzle-orm/*": ["./node_modules/drizzle-orm/*"],
      "winston": ["./node_modules/winston"],
      "axios": ["./node_modules/axios"],
      "@neondatabase/serverless": ["./node_modules/@neondatabase/serverless"],
      "zod": ["./node_modules/zod"],
      "viem": ["./node_modules/viem"],
      "viem/*": ["./node_modules/viem/*"],
      "vitest": ["./node_modules/vitest"],
    },
    "types": ["vitest", "vitest/globals"]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "../shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/**/*"
  ]
}
