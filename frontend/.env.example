# ======================== PUBLIC VARIABLES ========================
# These are safe to expose in client-side code (no secrets)

# Groq AI API Key (get from https://console.groq.com)
GROQ_API_KEY=

# Sideshift Bridge Integration (optional)
NEXT_PUBLIC_SIDESHIFT_API_KEY=
NEXT_PUBLIC_AFFILIATE_ID=

# Firebase Configuration (public configs only - safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Reward Token Contract Address (deployed contract)
NEXT_PUBLIC_REWARD_TOKEN_ADDRESS=

# ======================== PRIVATE/SERVER-SIDE SECRETS ========================
# IMPORTANT: Never use NEXT_PUBLIC_ prefix for these variables
# These should ONLY be used in server-side code (API routes, middleware, etc.)

# Brevo Email Service (get from https://www.brevo.com)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# Admin Configuration
ADMIN_MASTER_EMAIL=

# Database Connection
DATABASE_URL=
MONGODB_URI=

# Firebase Service Account (server-side only)
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Format: paste entire JSON as a single line (the app handles \n in private_key automatically)
FIREBASE_SERVICE_ACCOUNT_KEY=

# Token Owner Wallet Private Key (deployer/owner account)
# CRITICAL: This is a PRIVATE KEY - never expose in client code or version control
# Use only in server-side functions (API routes, authorized backend logic)
REWARD_TOKEN_OWNER_PRIVATE_KEY=

# Sepolia RPC URL (Alchemy or Infura)
# Get from Alchemy (https://dashboard.alchemy.com) or Infura (https://infura.io)
# Format: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SEPOLIA_RPC_URL=